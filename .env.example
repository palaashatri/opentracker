# Digital Twin Earth — Environment Variables
# Copy this file to .env and fill in your values.
# The application runs fully on mock data without any of these set.

# ─── Feed selection ───────────────────────────────────────────────────────────
# Options: mock (default), opensky, adsb
INGESTION_FEED_FLIGHT=mock

# Options: mock (default), aisstream, aishub
INGESTION_FEED_SHIP=mock

# ─── OpenSky Network (optional auth, higher rate limits) ─────────────────────
# Register free at: https://opensky-network.org/
OPENSKY_USERNAME=
OPENSKY_PASSWORD=

# ─── AISStream.io (required for aisstream feed) ───────────────────────────────
# Get free key at: https://aisstream.io
AISSTREAM_API_KEY=

# ─── AISHub (required for aishub feed) ───────────────────────────────────────
# Register free at: https://www.aishub.net/join-us
AISHUB_USERNAME=

# ─── Satellites ───────────────────────────────────────────────────────────────
SATELLITES_ENABLED=true
# Custom TLE URL (default: Celestrak active satellites)
# CELESTRAK_TLE_URL=https://celestrak.org/NORAD/elements/gp.php?GROUP=active&FORMAT=tle

# ─── Mock data (used when INGESTION_FEED_*=mock) ─────────────────────────────
MOCK_SEED=42
MOCK_FLIGHTS_COUNT=500
MOCK_SHIPS_COUNT=200
MOCK_SATELLITES_COUNT=100
INGESTION_SIM_INTERVAL_MS=1000

# ─── Gateway ──────────────────────────────────────────────────────────────────
GATEWAY_API_KEY=dev-key
# Comma-separated allowed CORS origins
# GATEWAY_CORS_ORIGINS=http://localhost:4200

# ─── Infrastructure (only override if not using docker-compose) ───────────────
# SPRING_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/digitaltwin
# SPRING_DATASOURCE_USERNAME=dt_user
# SPRING_DATASOURCE_PASSWORD=dt_pass
# SPRING_REDIS_HOST=localhost
